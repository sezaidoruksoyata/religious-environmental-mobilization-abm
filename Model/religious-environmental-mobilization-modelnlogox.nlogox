<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[globals [
  num-agents
  num-communities
  baseline-stewardship
  baseline-trust-science
  baseline-polarization
  climate-risk-level
  institutional-capacity-level
  activism-cost
  mobilization-threshold
  leader-types
  scenario-mode
]

turtles-own [
  community-id
  leader-type
  stewardship-belief
  trust-in-science
  trust-in-religious-leader
  political-identity
  climate-risk-exposure
  community-norm-strength
  perceived-cost-of-activism
  moral-obligation
  environmental-concern
  mobilization-score
  mobilization-status
]

to setup
  let selected-scenario "baseline"

  if is-string? scenario-mode [
    set selected-scenario scenario-mode
  ]

  clear-all

  set scenario-mode selected-scenario

  set-default-parameters
  setup-leaders

  create-turtles num-agents [
    setxy random-xcor random-ycor
    set size 0.7

    set community-id random num-communities
    set leader-type item community-id leader-types

    set stewardship-belief bounded-random baseline-stewardship 15
    set trust-in-science bounded-random baseline-trust-science 18
    set trust-in-religious-leader bounded-random 65 15
    set political-identity bounded-random baseline-polarization 20
    set climate-risk-exposure bounded-random climate-risk-level 20
    set community-norm-strength 10
    set perceived-cost-of-activism bounded-random activism-cost 15

    set environmental-concern 0
    set moral-obligation 0
    set mobilization-score 0
    set mobilization-status "passive"
  ]

  ask turtles [
    update-community-norm
    update-scores
    update-status
  ]

  reset-ticks
end

to set-default-parameters
  set num-agents 1000
  set num-communities 20

  set baseline-stewardship 65
  set baseline-trust-science 55
  set baseline-polarization 45
  set climate-risk-level 50
  set institutional-capacity-level 50
  set activism-cost 50
  set mobilization-threshold 40

  if scenario-mode = "high-stewardship" [
    set baseline-stewardship 90
  ]

  if scenario-mode = "high-risk" [
    set climate-risk-level 85
  ]

  if scenario-mode = "high-polarization" [
    set baseline-polarization 80
  ]

  if scenario-mode = "high-capacity" [
    set institutional-capacity-level 85
    set activism-cost 35
  ]

  if scenario-mode = "combined-activation" [
    set baseline-stewardship 85
    set baseline-trust-science 75
    set climate-risk-level 80
    set institutional-capacity-level 85
    set activism-cost 30
  ]

  if scenario-mode = "risk-activist" [
    set climate-risk-level 85
  ]

  if scenario-mode = "activist-capacity" [
    set institutional-capacity-level 85
    set activism-cost 35
  ]

  if scenario-mode = "risk-capacity" [
    set climate-risk-level 85
    set institutional-capacity-level 85
    set activism-cost 35
  ]

  if scenario-mode = "full-alignment" [
    set baseline-stewardship 85
    set baseline-trust-science 75
    set climate-risk-level 85
    set institutional-capacity-level 85
    set activism-cost 30
  ]
end
to setup-leaders
  set leader-types []

  if scenario-mode = "activist-leader" [
    set leader-types n-values num-communities [ "activist" ]
  ]

  if scenario-mode = "risk-activist" [
    set leader-types n-values num-communities [ "activist" ]
  ]

  if scenario-mode = "activist-capacity" [
    set leader-types n-values num-communities [ "activist" ]
  ]

  if scenario-mode = "full-alignment" [
    set leader-types n-values num-communities [ "activist" ]
  ]

  if scenario-mode = "skeptical-leader" [
    set leader-types n-values num-communities [ "skeptical" ]
  ]

  if leader-types = [] [
    let i 0
    while [i < num-communities] [
      if (i mod 4 = 0) [
        set leader-types lput "silent" leader-types
      ]

      if (i mod 4 = 1) [
        set leader-types lput "moderate" leader-types
      ]

      if (i mod 4 = 2) [
        set leader-types lput "activist" leader-types
      ]

      if (i mod 4 = 3) [
        set leader-types lput "skeptical" leader-types
      ]

      set i i + 1
    ]
  ]
end

to go
  ask turtles [
    update-climate-risk
    update-community-norm
    update-scores
    update-status
  ]

  tick
end

to update-climate-risk
  set climate-risk-exposure clamp
    (climate-risk-exposure
    + ((climate-risk-level - climate-risk-exposure) * 0.05)
    + (random-float 2 - 1))
    0
    100
end

to update-community-norm
  let my-community community-id
  let community-size count turtles with [community-id = my-community]

  if community-size > 0 [
    let active-members count turtles with [
      community-id = my-community and
      (mobilization-status = "norm-supporter" or mobilization-status = "mobilized")
    ]

    let active-share (active-members / community-size) * 100
    let leader-effect leader-climate-frame leader-type

    set community-norm-strength clamp
      ((active-share * 0.70) + (leader-effect * 0.30))
      0
      100
  ]
end

to update-scores
  let leader-effect leader-climate-frame leader-type

  set environmental-concern clamp
    ((climate-risk-exposure * 0.35)
    + (trust-in-science * 0.30)
    + (stewardship-belief * 0.15)
    - (political-identity * 0.20))
    0
    100

  set moral-obligation clamp
    ((stewardship-belief * 0.35)
    + (trust-in-religious-leader * 0.20)
    + (community-norm-strength * 0.25)
    + (leader-effect * 0.20))
    0
    100

  set mobilization-score clamp
    ((environmental-concern * 0.30)
    + (moral-obligation * 0.30)
    + (community-norm-strength * 0.20)
    + (institutional-capacity-level * 0.20)
    - (perceived-cost-of-activism * 0.25)
    - (political-identity * 0.20))
    0
    100
end

to update-status
  if leader-type = "skeptical" and political-identity > 60 and trust-in-science < 45 [
    set mobilization-status "resistant"
    recolor
    stop
  ]

  if mobilization-score > mobilization-threshold [
    set mobilization-status "mobilized"
    recolor
    stop
  ]

  if moral-obligation > 60 and environmental-concern > 50 [
    set mobilization-status "norm-supporter"
    recolor
    stop
  ]

  if stewardship-belief > 65 and moral-obligation > 50 [
    set mobilization-status "symbolic-steward"
    recolor
    stop
  ]

  if environmental-concern > 50 [
    set mobilization-status "concerned"
    recolor
    stop
  ]

  set mobilization-status "passive"
  recolor
end

to recolor
  if mobilization-status = "passive" [
    set color gray
  ]

  if mobilization-status = "concerned" [
    set color yellow
  ]

  if mobilization-status = "symbolic-steward" [
    set color orange
  ]

  if mobilization-status = "norm-supporter" [
    set color blue
  ]

  if mobilization-status = "mobilized" [
    set color green
  ]

  if mobilization-status = "resistant" [
    set color red
  ]
end

to-report leader-climate-frame [ltype]
  if ltype = "silent" [
    report 5
  ]

  if ltype = "moderate" [
    report 35
  ]

  if ltype = "activist" [
    report 80
  ]

  if ltype = "skeptical" [
    report -30
  ]

  report 0
end

to-report bounded-random [center spread]
  let value random-normal center spread
  report clamp value 0 100
end

to-report clamp [value minimum maximum]
  if value < minimum [
    report minimum
  ]

  if value > maximum [
    report maximum
  ]

  report value
end

to scenario-baseline
  set scenario-mode "baseline"
  setup
end

to scenario-high-stewardship
  set scenario-mode "high-stewardship"
  setup
end

to scenario-high-risk
  set scenario-mode "high-risk"
  setup
end

to scenario-activist-leader
  set scenario-mode "activist-leader"
  setup
end

to scenario-skeptical-leader
  set scenario-mode "skeptical-leader"
  setup
end

to scenario-high-polarization
  set scenario-mode "high-polarization"
  setup
end

to scenario-high-capacity
  set scenario-mode "high-capacity"
  setup
end

to scenario-combined-activation
  set scenario-mode "combined-activation"
  setup
end

to scenario-risk-activist
  set scenario-mode "risk-activist"
  setup
end

to scenario-activist-capacity
  set scenario-mode "activist-capacity"
  setup
end

to scenario-risk-capacity
  set scenario-mode "risk-capacity"
  setup
end

to scenario-full-alignment
  set scenario-mode "full-alignment"
  setup
end

to setup-sensitivity [chosen-threshold]
  let selected-scenario "baseline"

  if is-string? scenario-mode [
    set selected-scenario scenario-mode
  ]

  clear-all

  set scenario-mode selected-scenario

  set-default-parameters
  set mobilization-threshold chosen-threshold
  setup-leaders

  create-turtles num-agents [
    setxy random-xcor random-ycor
    set size 0.7

    set community-id random num-communities
    set leader-type item community-id leader-types

    set stewardship-belief bounded-random baseline-stewardship 15
    set trust-in-science bounded-random baseline-trust-science 18
    set trust-in-religious-leader bounded-random 65 15
    set political-identity bounded-random baseline-polarization 20
    set climate-risk-exposure bounded-random climate-risk-level 20
    set community-norm-strength 10
    set perceived-cost-of-activism bounded-random activism-cost 15

    set environmental-concern 0
    set moral-obligation 0
    set mobilization-score 0
    set mobilization-status "passive"
  ]

  ask turtles [
    update-community-norm
    update-scores
    update-status
  ]

  reset-ticks
end]]></code>
