        <metric>count turtles with [mobilization-status = "symbolic-steward"]</metric>
        <metric>count turtles with [mobilization-status = "concerned"]</metric>
        <metric>count turtles with [mobilization-status = "resistant"]</metric>
        <metric>count turtles with [mobilization-status = "passive"]</metric>
        <metric>mean [climate-risk-exposure] of turtles</metric>
        <metric>mean [environmental-concern] of turtles</metric>
        <metric>mean [moral-obligation] of turtles</metric>
        <metric>mean [community-norm-strength] of turtles</metric>
        <metric>mean [mobilization-score] of turtles</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="scenario-mode">
          <value value="&quot;baseline&quot;"></value>
          <value value="&quot;high-stewardship&quot;"></value>
          <value value="&quot;activist-capacity&quot;"></value>
          <value value="&quot;full-alignment&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="mobilization-threshold">
          <value value="30"></value>
          <value value="35"></value>
          <value value="40"></value>
          <value value="45"></value>
          <value value="50"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
  </experiments>
</model>
